    {
      "description": "Converts the recording to base64 every second, can be used for transferring audio as string for sound streaming.",
      "fullName": "Save Recording As Base64 (Real-Time)",
      "functionType": "Action",
      "group": "Streaming",
      "name": "Stream",
      "sentence": "Save Recording In Variable _PARAM1_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [
            {
              "type": {
                "value": "BuiltinCommonInstructions::Once"
              },
              "parameters": []
            }
          ],
          "actions": [
            {
              "type": {
                "value": "AdvancedMicrophone::RequestMC"
              },
              "parameters": [
                "",
                ""
              ]
            }
          ]
        },
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [
            {
              "type": {
                "value": "RepeatEveryXSeconds::Repeat"
              },
              "parameters": [
                "",
                "\"loop1\"",
                "5",
                ""
              ]
            }
          ],
          "actions": [
            {
              "type": {
                "value": "Wait"
              },
              "parameters": [
                "0.2"
              ]
            }
          ],
          "events": [
            {
              "type": "BuiltinCommonInstructions::JsCode",
              "inlineCode": [
                "if (!window.gdMicSystem) window.gdMicSystem = {};",
                "",
                "if (window.gdMicSystem.mediaRecorder) return;",
                "",
                "const variableUsed = eventsFunctionContext.getArgument(\"VariableUsed\");",
                "",
                "navigator.mediaDevices.getUserMedia({ audio: true })",
                ".then(stream => {",
                "",
                "    const mediaRecorder = new MediaRecorder(stream);",
                "",
                "        window.gdMicSystem.mediaRecorder = mediaRecorder;",
                "            window.gdMicSystem.latestChunk = null;",
                "",
                "                mediaRecorder.ondataavailable = function(e) {",
                "                        if (e.data && e.data.size > 0) {",
                "",
                "                                    window.gdMicSystem.latestChunk = e.data;",
                "",
                "                                                            const reader = new FileReader();",
                "",
                "                                                                        reader.onloadend = function() {",
                "                                                                                        const base64data = reader.result.split(\",\")[1];",
                "                                                                                                        variableUsed.setString(base64data);",
                "                                                                                                                    };",
                "",
                "                                                                                                                                reader.readAsDataURL(e.data);",
                "                                                                                                                                        }",
                "                                                                                                                                            };",
                "",
                "                                                                                                                                                mediaRecorder.start(250);",
                "",
                "                                                                                                                                                    console.log(\"Recorder started\");",
                "",
                "                                                                                                                                                    })",
                "                                                                                                                                                    .catch(err => {",
                "                                                                                                                                                        console.error(\"error:\", err);",
                "                                                                                                                                                        });"
              ],
              "parameterObjects": "",
              "useStrict": true,
              "eventsSheetExpanded": false
            }
          ]
        }
      ],
      "parameters": [
        {
          "description": "Variable To Store",
          "name": "VariableUsed",
          "type": "variable"
        }
      ],
      "objectGroups": []
    },
