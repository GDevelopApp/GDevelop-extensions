                "textG": 0,
                "textR": 0
              },
              "comment": "Guardar los identificadores en sus respectivos grupos"
            },
            {
              "type": "BuiltinCommonInstructions::Standard",
              "conditions": [
                {
                  "type": {
                    "value": "BehaviorActivated"
                  },
                  "parameters": [
                    "Object",
                    "Behavior"
