                  "parameters": [
                    "_groupTMP",
                    "=",
                    "ObjGroup"
                  ]
                }
              ],
              "events": [
                {
                  "type": "BuiltinCommonInstructions::JsCode",
                  "inlineCode": [
                    "const ext = runtimeScene.getGame().getVariablesForExtension(\"FocusObjects\");",
                    "",
                    "const focusList = ext.get(\"_focusList\");",
                    "const currentObjFocusList = ext.get(\"_currentObjFocusList\");",
                    "const idTMP = ext.get(\"_idTMP\").getAsNumber();",
                    "const groupTMP = ext.get(\"_groupTMP\").getAsString();",
                    "",
                    "focusList.getChild(groupTMP).getChildAt(idTMP).setNumber(idTMP); // Guardar los ids en el grupo",
                    "currentObjFocusList.getChild(groupTMP).setNumber(0); // Guardar el id de enfoque",
                    ""
                  ],
                  "parameterObjects": "",
                  "useStrict": true,
                  "eventsSheetExpanded": false
                },
                {
                  "disabled": true,
                  "type": "BuiltinCommonInstructions::Standard",
                  "conditions": [],
                  "actions": [
