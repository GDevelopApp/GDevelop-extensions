                      },
                      "parameters": [
                        "\"focusList = \" + ToJSON(_focusList) + \"\ncurrentListFocus = \" + ToJSON(_currentObjFocusList[_currentGroup])",
                        "\"info\"",
                        ""
                      ]
                    }
                  ]
                }
              ]
            }
