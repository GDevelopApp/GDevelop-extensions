    {
      "description": "Limit the maximum speed an object will move from (non-physics) forces.",
      "fullName": "Enforce max movement speed",
      "name": "MaxMovementSpeed_Forces",
      "objectType": "",
      "eventsFunctions": [
        {
          "fullName": "",
          "functionType": "Action",
          "name": "doStepPostEvents",
          "sentence": "",
          "events": [
            {
              "type": "BuiltinCommonInstructions::Standard",
              "conditions": [
                {
                  "type": {
                    "value": "Speed"
                  },
                  "parameters": [
                    "Object",
                    ">",
                    "MaximumSpeed"
                  ]
                }
              ],
              "actions": [
                {
                  "type": {
                    "value": "SetNumberVariable"
                  },
                  "parameters": [
                    "CurrentSpeedX",
                    "=",
                    "Object.ForceX()"
                  ]
                },
                {
                  "type": {
                    "value": "SetNumberVariable"
                  },
                  "parameters": [
                    "CurrentSpeedY",
                    "=",
                    "Object.ForceY()"
                  ]
                },
                {
                  "type": {
                    "value": "SetNumberVariable"
                  },
                  "parameters": [
                    "CurrentSpeed",
                    "=",
                    "Object.ForceLength()"
                  ]
                },
                {
                  "type": {
                    "value": "ClearForces"
                  },
                  "parameters": [
                    "Object"
                  ]
                },
                {
                  "type": {
                    "value": "AddForceXY"
                  },
                  "parameters": [
                    "Object",
                    "CurrentSpeedX * MaximumSpeed / CurrentSpeed",
                    "CurrentSpeedY * MaximumSpeed / CurrentSpeed",
                    "1"
                  ]
                }
              ]
            }
          ],
          "parameters": [
            {
              "description": "Object",
              "name": "Object",
              "type": "object"
            },
            {
              "description": "Behavior",
              "name": "Behavior",
              "supplementaryInformation": "SpeedRestrictions::MaxMovementSpeed_Forces",
              "type": "behavior"
            }
          ],
